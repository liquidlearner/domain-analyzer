# ─── Database ────────────────────────────────────────────────
# Start PostgreSQL: docker compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pd_migration_analyzer

# ─── Encryption ──────────────────────────────────────────────
# AES-256-GCM key for encrypting PD API tokens at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=
ENCRYPTION_KEY_ID=v1

# ─── Authentication ───────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth (production only — not needed when dev bypass is enabled)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Dev Only ────────────────────────────────────────────────
# Enables "Dev Login" button on login page (bypasses Google OAuth)
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# ─── Background Jobs (Inngest) ───────────────────────────────
# Optional for local dev — evaluations run inline without Inngest
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ─── Optional: Observability ─────────────────────────────────
# SENTRY_DSN=
